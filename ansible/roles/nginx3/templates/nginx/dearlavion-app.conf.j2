# ======================
# Upstreams (Docker services)
# ======================
upstream web_ui {
    server dearlavion-web-ui:{{ web_ui_port }};
}

upstream api_gateway {
    server dearlavion-gateway-service:{{ gateway_internal_port }};
}

upstream minio_api {
    server dearlavion-minio:{{ minio_internal_s3_api_port }};
}

upstream minio_console {
    server dearlavion-minio:{{ minio_internal_web_console_port }};
}

# ======================
# HTTPS server
# ======================
server {
    listen 443 ssl;
    server_name {{ server_names | join(' ') }};

    ssl_certificate /etc/letsencrypt/live/{{ server_names[0] }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ server_names[0] }}/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;

    # ACME HTTP-01 challenge for Certbot
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    resolver 127.0.0.11 valid=10s ipv6=off;
    resolver_timeout 5s;

    # ======================
    # Frontend
    # ======================
    location / {
        proxy_pass http://web_ui;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_connect_timeout 5s;
        proxy_read_timeout 60s;

        proxy_next_upstream error timeout http_502 http_503 http_504;
        proxy_next_upstream_tries 3;
    }

    # All API traffic → Spring Gateway
    location /api/ {
        proxy_pass http://api_gateway;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Required for WebSocket
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        proxy_connect_timeout 5s;
        proxy_read_timeout 60s;

        proxy_next_upstream error timeout http_502 http_503 http_504;
        proxy_next_upstream_tries 3;
    }
}

# ======================
# MinIO S3 API
# ======================
server {
    listen 443 ssl;
    server_name {{ minio_server_url }};

    ssl_certificate /etc/letsencrypt/live/{{ server_names[0] }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ server_names[0] }}/privkey.pem;

    client_max_body_size 0;                  # ← moved out of location block
    proxy_buffering         off;             # ← added
    proxy_request_buffering off;             # ← added

    location / {
        proxy_pass http://minio_api;
        proxy_http_version 1.1;              # ← added

        proxy_set_header Host               $http_host;   # ← was $host
        proxy_set_header X-Real-IP          $remote_addr;
        proxy_set_header X-Forwarded-For    $proxy_add_x_forwarded_for;  # ← added
        proxy_set_header X-Forwarded-Proto  $scheme;

        proxy_read_timeout  300s;            # ← added
        proxy_send_timeout  300s;            # ← added
    }
}

# ======================
# MinIO Console          (no changes needed here)
# ======================
server {
    listen 443 ssl;
    server_name {{ minio_browser_url }};

    ssl_certificate /etc/letsencrypt/live/{{ server_names[0] }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ server_names[0] }}/privkey.pem;

    location / {
        proxy_pass http://minio_console;
        proxy_http_version 1.1;              # ← added
        proxy_set_header Host      $http_host;  # ← was $host
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header Upgrade   $http_upgrade;  # ← added (console uses WebSocket)
        proxy_set_header Connection "upgrade";     # ← added
    }
}

# ======================
# HTTP redirect to HTTPS
# ======================
server {
    listen 80;
    server_name {{ server_names | join(' ') }};

    # ACME challenge for Certbot (must be **before** redirect)
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    # Redirect everything else to HTTPS
    location / {
        return 301 https://$host$request_uri;
    }
}
