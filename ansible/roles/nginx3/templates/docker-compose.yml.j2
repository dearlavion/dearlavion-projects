services:
  nginx:
    image: nginx:1.25-alpine
    container_name: dearlavion-nginx
    ports:
      - "{{ nginx_http_port }}:80"    # HTTP
      - "{{ nginx_https_port }}:443"  # HTTPS

    volumes:
      - ./nginx/nginx.conf:/etc/nginx/nginx.conf:ro
      - ./nginx/dearlavion-app.conf:/etc/nginx/conf.d/default.conf:ro
      - /etc/letsencrypt/live:/etc/letsencrypt/live:ro
      - /etc/letsencrypt/archive:/etc/letsencrypt/archive:rw
      - /etc/letsencrypt/renewal:/etc/letsencrypt/renewal:rw
      - /opt/dearlavion/certbot-webroot:/var/www/certbot
    networks:
      - "{{ dearlavion_network }}"

networks:
  "{{ dearlavion_network }}":
    external: true